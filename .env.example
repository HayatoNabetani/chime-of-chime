# ============================================================
# 通知先設定 (カンマ区切りで複数指定可)
#   console: 標準出力に出すだけ (動作確認用)
#   line   : LINE Messaging API (Push message)
#   slack  : Slack Incoming Webhook
# 例: NOTIFIER=line,slack
# ============================================================
NOTIFIER=console

# ------------------------------------------------------------
# LINE Messaging API
#   https://developers.line.biz/ からチャネル作成
#   チャネルアクセストークン(長期) と 通知先ユーザーID を取得
# ------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ------------------------------------------------------------
# Slack Incoming Webhook
#   Slackアプリ作成 → Incoming Webhooksを有効化
#   投稿先チャンネルを選んでWebhook URLを発行
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=

# ============================================================
# 検知パラメータ (任意: プロファイル作成後の推奨値があれば上書き)
# ============================================================
# CHIME_RMS=0.003       # マイクが拾う最小の音量 (RMS)
# CHIME_FLATNESS=0.30   # これより平坦ならノイズ扱い (小さいほど純音)
# CHIME_PROM=8          # ピーク優位性の下限 (大きいほど厳しい)
# CHIME_DEBUG=0         # 1で全フレームの判定ログを出力
# CHIME_DRY_RUN=0       # 1で通知を送らず検知ログのみ出力 (調整用)
